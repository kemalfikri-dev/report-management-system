generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model users {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reports   Report[]
}

model reports {
  id        String   @id@default(cuid())
  title     String
  description String 
  status    String 

  userId    String
  user      users @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
